# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.js

# Testing
/coverage

# Next.js build output
/.next/
/out/

# Production
/build

# Misc
.DS_Store
*.pem

# Secrets
# Ignore all local environment variable files.
.env
.env.local
.env.development
.env.test
.env.production

# Ignore the service account key file.
# It is best practice to use environment variables, but this ensures the file is never committed.
service-account.json
service-account-key.json

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories and files
.vscode
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
